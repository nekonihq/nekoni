# Agent
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_NAME=nekoni
# LAN URL of this machine — embedded in the QR code so the phone can reach the agent.
# Find your LAN IP:
#   macOS : ipconfig getifaddr en0
#   Linux : hostname -I | awk '{print $1}'
#   Windows: ipconfig | findstr "IPv4"
AGENT_URL=http://192.168.1.x:8000

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Signal server — default hosted instance, or self-host (see apps/signal/DEPLOY.md)
SIGNAL_URL=wss://signal.nekoni.dev

# Dashboard auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=nekoni

# Storage paths (Docker volume mounts — override only if changing mount layout)
AGENT_KEYS_DIR=/data/keys
CHROMA_PATH=/data/chroma
SQLITE_PATH=/data/sqlite/memory.db
