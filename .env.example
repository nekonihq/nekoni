# Agent
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_NAME=nekoni

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Signal server — externally hosted, required
# e.g. wss://signal.example.com or ws://192.168.1.10:3000
SIGNAL_URL=wss://your-signal-server.example.com

# Dashboard auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=nekoni

# Storage paths (Docker volume mounts — override only if changing mount layout)
AGENT_KEYS_DIR=/data/keys
CHROMA_PATH=/data/chroma
SQLITE_PATH=/data/sqlite/memory.db
